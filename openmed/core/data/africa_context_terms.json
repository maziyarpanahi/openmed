  "patterns": [
    {
      "id": "named_healthcare_facility",
      "template": "\\b(?!(?i:{facility_name_stopwords})\\s+(?i:{facility_cues})\\b)(?:[A-ZÀ-ÖØ-Þ][\\w'’.-]*\\s+){1,5}(?i:{facility_cues})\\b",
      "entity_type": "ORGANIZATION",
      "priority": 9,
      "flags": 0,
      "base_score": 0.9,
      "context_boost": 0.0,
      "safety_sweep_requires_context": false
    },
    {
      "id": "mobile_money_reference",
      "template": "\\b(?i:(?:{mobile_money_operators})\\s+(?:(?:{mobile_money_reference_cues})\\s*[:#-]?\\s*)?)(?=[A-Z0-9 -]{8,24}\\b)(?=[A-Z0-9 -]*\\d)[A-Z0-9][A-Z0-9 -]{6,22}[A-Z0-9]\\b",
      "entity_type": "ACCOUNT_NUMBER",
      "priority": 10,
      "flags": 0,
      "base_score": 0.55,
      "context_boost": 0.0,
      "safety_sweep_requires_context": false
    },
    {
      "id": "ethnic_affiliation",
      "template": "\\b(?:{ethnic_affiliations})\\b",
      "entity_type": "ETHNICITY",
      "priority": 8,
      "flags": 2,
      "base_score": 0.55,
      "context_boost": 0.4,
      "context_term_set": "ethnic_affiliation_context",
      "requires_context": true,
      "safety_sweep_requires_context": true
    }
  ],
